    },
    {
        "type": "table",
        "img_path": "images/2ea277a8b1009e121302fc85a79f81eba08fa5648ec445f1c9b4495255da1af4.jpg",
        "table_caption": [],
        "table_footnote": [],
        "table_body": "<table><tr><td colspan=\"4\">今天</td></tr><tr><td>晴朗</td><td>晴朗</td><td>多云</td><td>下雨</td></tr><tr><td>昨天多云</td><td>0.50</td><td>0.375</td><td>0.125</td></tr><tr><td></td><td>0.25</td><td>0.125</td><td>0.625</td></tr><tr><td>下雨</td><td>0.25</td><td>0.375</td><td>0.375</td></tr></table>",
        "bbox": [
            192,
