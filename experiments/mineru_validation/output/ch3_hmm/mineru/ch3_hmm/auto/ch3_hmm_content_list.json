    {
        "type": "text",
        "text": "马尔科夫模型的形式化定义",
        "text_level": 2,
        "bbox": [
            226,
            175,
            776,
            262
        ],
        "page_idx": 6
    },
    {
        "type": "equation",
        "img_path": "images/1f4b21386179fb9c247990d89a3a718f7d2fdd8754406c6a239f4141f71382cb.jpg",
        "text": "$$\n\\mu = ( \\mathrm { S } , \\mathrm { A } , \\pi )\n$$",
        "text_format": "latex",
        "bbox": [
            176,
            292,
            341,
            359
        ],
        "page_idx": 6
    },
    {
        "type": "text",
        "text": "S ={s₁}→状态集合",
        "bbox": [
            177,
            375,
            387,
            435
        ],
        "page_idx": 6
    },
    {
        "type": "text",
        "text": "A= {aj}→状态转移概率矩阵",
        "bbox": [
            178,
            457,
            471,
            514
        ],
        "page_idx": 6
    },
    {
        "type": "text",
        "text": "$\\pi = \\left\\{ \\pi _ { \\mathrm { i } } \\right\\}$ →初始概率矩阵",
        "bbox": [
            179,
            531,
            442,
            590
        ],
        "page_idx": 6
    },
    {
        "type": "text",
        "text": "{晴朗，多云，下雨}",
        "bbox": [
            580,
            287,
            758,
            333
        ],
        "page_idx": 6
    },
    {
        "type": "equation",
        "img_path": "images/d994777666b67ebd62969440d5419525569039d4fef3209bfca692aa13dc260c.jpg",
        "text": "$$\n\\begin{array} { r l } & { \\frac { A _ { \\widehat { \\mathbf { A } } } } { B } \\mathbb { A } } \\\\ { \\frac { A _ { \\widehat { \\mathbf { A } } } } { B } \\mathbb { H } } & { \\left( \\begin{array} { l l l } { \\mathbb { H } _ { \\widehat { \\mathbf { B } } } ^ { \\pm } \\mathbb { H } } & { \\widehat { \\mathbf { S } } \\widehat { \\mathbf { z } } } & { \\widehat { \\mathbb { F } } \\overline { { \\mathbb { H } } } } \\\\ { 0 . 5 0 } & { 0 . 3 7 5 } & { 0 . 1 2 5 } \\\\ { 0 . 2 5 } & { 0 . 1 2 5 } & { 0 . 6 2 5 } \\\\ { 0 . 2 5 } & { 0 . 3 7 5 } & { 0 . 3 7 5 } \\end{array} \\right) } \\end{array}\n$$",
        "text_format": "latex",
        "bbox": [
            584,
            350,
            841,
            583
        ],
        "page_idx": 6
    },
    {
        "type": "text",
