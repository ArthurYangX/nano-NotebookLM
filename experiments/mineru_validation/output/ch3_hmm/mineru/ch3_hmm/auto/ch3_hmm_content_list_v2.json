    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "• Markov, 1913"
                    }
                ]
            },
            "bbox": [
                165,
                242,
                334,
                279
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "• 随机过程"
                    }
                ]
            },
            "bbox": [
                166,
                292,
                284,
                333
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "又称“随机函数”，是随时间而随机变化的过程"
                    }
                ]
            },
            "bbox": [
                201,
                346,
                670,
                387
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "• 马尔科夫模型描述了一类重要的随机过程"
                    }
                ]
            },
            "bbox": [
                166,
                400,
                576,
                442
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "设系统有N个状态 "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\cal S } = \\{ s _ { 1 } , s _ { 2 } , \\cdots , s _ { N } \\}"
                    }
                ]
            },
            "bbox": [
                196,
                481,
                522,
                529
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "随着时间的推移，系统将从某一状态转移到另一状态。"
                    }
                ]
            },
            "bbox": [
                195,
                542,
                705,
                587
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { Q } = \\{ q _ { 1 } , q _ { 2 } , \\cdots , q _ { T } \\}"
                    },
                    {
                        "type": "text",
                        "content": "为一随机变量序列， "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\textstyle q _ { t } \\in S , t = 1 , 2 , \\cdots , T"
                    }
                ]
            },
            "bbox": [
                196,
                603,
                721,
                650
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "则系统在时间t处于状态 "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\dot { s } _ { j }"
                    },
                    {
                        "type": "text",
                        "content": "的概率取决于其在时间1,2,…，t-1的状态"
                    }
                ]
            },
            "bbox": [
                195,
                661,
                817,
                711
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P ( q _ { t } = s _ { j } \\mid q _ { t - 1 } = s _ { i } , q _ { t - 2 } = s _ { k } , \\cdots )",
                "math_type": "latex",
                "image_source": {
                    "path": "images/3faa7cd84fab300ddd0ff8764b741f3049c073f9ab76c13efcf4bfa85bdbb242.jpg"
                }
            },
            "bbox": [
                214,
                759,
                580,
                822
            ]
        },
        {
            "type": "page_header",
            "content": {
                "page_header_content": [
                    {
                        "type": "text",
                        "content": "3.1 马尔科夫模型"
                    }
                ]
            },
            "bbox": [
                28,
                62,
                256,
                112
            ]
        },
        {
            "type": "page_header",
            "content": {
                "page_header_content": []
            },
            "bbox": [
                936,
                51,
                996,
                131
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "• 一阶马尔可夫过程"
                    }
                ],
                "level": 2
            },
            "bbox": [
                165,
                240,
                400,
                287
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "如果系统在t时间的状态只与其在时间t-1的状态相关，则该随机过程称为一阶马尔可夫过程"
                    }
                ]
            },
            "bbox": [
                202,
                301,
                825,
                387
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P ( q _ { t } = s _ { j } \\mid q _ { t - 1 } = s _ { i } , q _ { t - 2 } = s _ { k } , \\cdots ) \\approx P ( q _ { t } = s _ { j } \\mid q _ { t - 1 } = s _ { i } )",
                "math_type": "latex",
                "image_source": {
                    "path": "images/83e7a829baef6110865c59fedf987d0be0deef848200d928faf80710bd708350.jpg"
                }
            },
            "bbox": [
                227,
                401,
                781,
                457
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "• 马尔可夫模型"
                    }
                ]
            },
            "bbox": [
                166,
                466,
                347,
                512
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "独立于时间t的随机过程"
                    }
                ]
            },
            "bbox": [
                202,
                527,
                446,
                568
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P ( q _ { t } = s _ { j } \\mid q _ { t - 1 } = s _ { i } ) = a _ { i j } , ( 1 \\leq i , j \\leq N )",
                "math_type": "latex",
                "image_source": {
                    "path": "images/3faff5abf7736b3ffe05b707e8a8f9ed957e5879c26aba710066d9a7fffc7ff0.jpg"
                }
            },
            "bbox": [
                213,
                590,
                571,
                642
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "a _ { i j }"
                    },
                    {
                        "type": "text",
                        "content": "称为状态转移概率"
                    }
                ]
            },
            "bbox": [
                211,
                670,
                440,
                731
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "a _ { i j }"
                    },
                    {
                        "type": "text",
                        "content": "须满足以下条件"
                    }
                ]
            },
            "bbox": [
                610,
                668,
                781,
                720
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "a _ { i j } \\geq 0",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a318b900654cd7f4da84c78543f3e4fc8eeb90eb63fedc42cbae9a207f890a1e.jpg"
                }
            },
            "bbox": [
                638,
                735,
                696,
                781
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\sum _ { j = 1 } ^ { N } a _ { i j } = 1",
                "math_type": "latex",
                "image_source": {
                    "path": "images/1858806d31d5f9714ce174ec509f552dea2723ecf292459adc1b0aa6c5268078.jpg"
                }
            },
            "bbox": [
                642,
                794,
                722,
                896
            ]
        },
        {
            "type": "page_header",
            "content": {
                "page_header_content": [
                    {
                        "type": "text",
                        "content": "3.1 马尔科夫模型"
                    }
                ]
            },
            "bbox": [
