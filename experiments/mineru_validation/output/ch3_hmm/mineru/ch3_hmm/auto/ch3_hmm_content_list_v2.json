            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mu = ( \\mathrm { S } , \\mathrm { A } , \\pi )",
                "math_type": "latex",
                "image_source": {
                    "path": "images/1f4b21386179fb9c247990d89a3a718f7d2fdd8754406c6a239f4141f71382cb.jpg"
                }
            },
            "bbox": [
                176,
                292,
                341,
                359
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "S ={s₁}→状态集合"
                    }
                ]
            },
            "bbox": [
                177,
                375,
                387,
                435
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "A= {aj}→状态转移概率矩阵"
                    }
                ]
            },
            "bbox": [
                178,
                457,
                471,
                514
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "\\pi = \\left\\{ \\pi _ { \\mathrm { i } } \\right\\}"
                    },
                    {
                        "type": "text",
                        "content": "→初始概率矩阵"
                    }
                ]
            },
            "bbox": [
