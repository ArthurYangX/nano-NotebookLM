                333
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array} { r l } & { \\frac { A _ { \\widehat { \\mathbf { A } } } } { B } \\mathbb { A } } \\\\ { \\frac { A _ { \\widehat { \\mathbf { A } } } } { B } \\mathbb { H } } & { \\left( \\begin{array} { l l l } { \\mathbb { H } _ { \\widehat { \\mathbf { B } } } ^ { \\pm } \\mathbb { H } } & { \\widehat { \\mathbf { S } } \\widehat { \\mathbf { z } } } & { \\widehat { \\mathbb { F } } \\overline { { \\mathbb { H } } } } \\\\ { 0 . 5 0 } & { 0 . 3 7 5 } & { 0 . 1 2 5 } \\\\ { 0 . 2 5 } & { 0 . 1 2 5 } & { 0 . 6 2 5 } \\\\ { 0 . 2 5 } & { 0 . 3 7 5 } & { 0 . 3 7 5 } \\end{array} \\right) } \\end{array}",
