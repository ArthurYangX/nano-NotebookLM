# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible API (e.g. codex proxy)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding model: "local" for sentence-transformers, or "api" for OpenAI embeddings
EMBEDDING_MODE=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Default AI backend: "claude" or "openai"
DEFAULT_BACKEND=claude

# Human-in-the-loop: "auto" (no intervention) or "interactive"
CHECKPOINT_MODE=interactive

# Data paths
COURSE_DATA_DIR=/Users/arthuryang/Desktop/大三学习/NLPProject
ARTIFACTS_DIR=./artifacts

# GraphRAG retriever (R4-4 + 2026-05-12 All-Courses fan-out)
# GRAPHRAG_ENABLED=1                  # ANY value other than 1/true/yes/on/enabled disables
#                                     #  graphrag entirely (v3 fail-safe inversion). Empty
#                                     #  / unset = default on. Disabling also skips the
#                                     #  All Courses fan-out below.
# GRAPHRAG_SCORE_GATE_TOP1=0.15       # cosine floor for graphrag admission (clamped to [0,1]).
# GRAPHRAG_FANOUT_CONCURRENCY=4       # max parallel per-course graph_search calls in All Courses
#                                     #  mode. Caps default-ThreadPool pressure so a burst of
#                                     #  All Courses chats can't starve notes/upload/mindmap.
# GRAPHRAG_COURSES_CACHE_TTL=60       # seconds the courses-with-KG list is cached after an
#                                     #  iterdir() scan. Newly-ingested courses appear within
#                                     #  this window in All Courses graphrag.
# GRAPHRAG_LOW_CONFIDENCE_CEILING=0.30 # cosine threshold (above admission floor) below which
#                                     #  a graphrag answer is flagged "_(本次检索置信度较低)_"
#                                     #  and the system prompt instructs the model to refuse
#                                     #  rather than confabulate. Path-B safety net 2026-05-13.
# NANO_NLM_DISABLE_EMBED_WARMUP=0     # 1 to skip the startup sentence-transformer warm-up.

# Qwen-RAFT optional backend (R4-5 fix-all v3, 2026-05-12)
# Talks to AutoDL `scripts/serve_openai.py` — an OpenAI-compatible FastAPI
# wrapper around Qwen2.5-7B-RAFT (start with `bash start_openai_server.sh`).
# Leave QWEN_RAFT_URL empty to disable the backend chip. The other vars
# are only consulted when QWEN_RAFT_URL is set.
#
# Prefer the AutoDL https port-mapped form (production / WAN). The raw
# http://host:8001 form is only safe over a localhost / SSH-tunneled
# loopback — `_validate_qwen_url` warns but does NOT reject it, and your
# chat prompts (which include RAG context + system instructions) will
# travel in plaintext if you point production at the bare http URL.
#
# Migration note: if your existing .env still points at the legacy
# Gradio service (URL ends in `.gradio.live`), update to the new
# serve_openai.py port — backend startup now logs a warning when it
# detects the legacy hostname.
# QWEN_RAFT_URL=https://your-autodl-mapped-host       # service root; /v1 suffix tolerated
# QWEN_RAFT_TOKEN=                                    # optional bearer (if you front it with a proxy)
# QWEN_RAFT_MODEL_NAME=qwen2.5-7b-raft                # surfaced as LLMResponse.model
# QWEN_RAFT_HTTP_TIMEOUT=60                           # read-phase timeout; connect/write/pool
                                                      # are clamped tighter internally (10/10/5s)
# QWEN_BACKEND_TIMEOUT_SECONDS=60                     # chat-path budget (outer wait_for).
                                                      # Raised 30 → 60 on 2026-05-13 after the
                                                      # qwen_monitor run showed Qwen2.5-7B-RAFT
                                                      # under load typically answers in 35-50s.
# QWEN_HEALTH_TTL_SECONDS=15                          # /api/status health probe cache
# QWEN_QUOTE_SOURCE_MIN_RATIO=0.25                    # SequenceMatcher quick_ratio floor for
                                                      # fuzzy-matching qwen-emitted blockquote
                                                      # text to graphrag chunks before attaching
                                                      # a `[Source: file, page]` tag. Substring
                                                      # match (post-whitespace-normalize) runs
                                                      # first; this floor only gates the
                                                      # SequenceMatcher fallback.

# ── Codex / OpenAI backend HTTP knobs ─────────────────────────────────
# OPENAI_REASONING_EFFORT=medium         # GPT-5+ reasoning depth before first
#                                          SSE delta. low / medium / high.
#                                          Default `medium` cuts first-token
#                                          wait from ~30-90s (codex proxy
#                                          default `high`) to ~5-15s while
#                                          keeping structured LaTeX quality.
#                                          Set to "auto" / empty to fall
#                                          through to the proxy's default.
# OPENAI_HTTP_TIMEOUT_SECONDS=600        # SSE chunk-to-chunk read timeout.
#                                          Default raised 120 → 600 because
#                                          codex GPT-5.4 reasoning silence
#                                          between deltas can exceed 2min on
#                                          dense per-file note generations,
#                                          causing concurrent streams to
#                                          ReadTimeout in lockstep and surface
#                                          as `all_files_failed` in the UI.
# OPENAI_EXECUTOR_WORKERS=24             # ThreadPoolExecutor cap shared by ALL
#                                          codex sync calls (complete + stream +
#                                          chat completions). Default raised
#                                          4 → 24 on 2026-05-13 — the 4-worker
#                                          cap was the real bottleneck behind
#                                          slow Notes generation (concurrency=8
#                                          + 1 review pass + occasional chat).
# OPENAI_STREAM_PUT_TIMEOUT_S=5.0        # how long a producer thread will wait
#                                          to enqueue an SSE chunk before
#                                          treating the consumer as dead.

# ── Full-course Notes (R4-6 LaTeX pipeline) ───────────────────────────
# NOTES_DEFAULT_CONCURRENCY=8            # default per-file parallelism. Raised
#                                          back to 8 on 2026-05-13 after the
#                                          executor bump to 24 unblocked it.
#                                          Frontend can still override per-
#                                          request via ChatRequest.concurrency
#                                          (hard cap 16).
# NOTES_PER_FILE_MAX_TOKENS=12288        # per-file LLM cap; lower if you hit
#                                          repeated truncation on small models
# NOTES_REVIEW_MAX_TOKENS=24576          # review pass cap; scales with N files

# ── Exam Prep (R5-2 closed-loop skill) ────────────────────────────────
# EXAM_PREP_LLM_TIMEOUT_SECONDS=120     # per-LLM-call timeout for plan + variant gen.
                                       # Raised 45 → 120 on 2026-05-13 — GPT-5.5
                                       # reasoning silence regularly exceeded 45s
                                       # on the plan call, causing 502s in /api/exam-prep/plan.
# EXAM_PREP_VARIANT_CONCURRENCY=4       # max concurrent codex calls during submit variant gen

# ── KG extraction (Stage A topics + Stage B per-chunk) ────────────────
# KG_STAGE_B_CONCURRENCY=10            # max parallel per-chunk Stage B LLM calls (10 is the
                                       # safe default for codex; bump on higher-throughput
                                       # backends, lower if you see rate-limit errors)
# KG_STAGE_A_TIMEOUT_SECONDS=30        # per-file Stage A wall-clock budget — codex cold-start
                                       # plus a 30-chunk-head prompt often brushes past 15s on
                                       # the first call; 30s gives headroom without hiding hangs
