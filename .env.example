# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible API (e.g. codex proxy)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding model: "local" for sentence-transformers, or "api" for OpenAI embeddings
EMBEDDING_MODE=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Default AI backend: "claude" or "openai"
DEFAULT_BACKEND=claude

# Human-in-the-loop: "auto" (no intervention) or "interactive"
CHECKPOINT_MODE=interactive

# Data paths
COURSE_DATA_DIR=/Users/arthuryang/Desktop/大三学习/NLPProject
ARTIFACTS_DIR=./artifacts

# GraphRAG retriever (R4-4)
# GRAPHRAG_ENABLED=1               # set 0/false/no/off/disabled to skip graphrag
# GRAPHRAG_SCORE_GATE_TOP1=0.15    # cosine floor for graphrag admission (clamped to [0,1])
# NANO_NLM_DISABLE_EMBED_WARMUP=0  # 1 to skip the startup sentence-transformer warm-up

# Qwen-RAFT optional backend (R4-5 fix-all v3, 2026-05-12)
# Talks to AutoDL `scripts/serve_openai.py` — an OpenAI-compatible FastAPI
# wrapper around Qwen2.5-7B-RAFT (start with `bash start_openai_server.sh`).
# Leave QWEN_RAFT_URL empty to disable the backend chip. The other vars
# are only consulted when QWEN_RAFT_URL is set.
#
# Prefer the AutoDL https port-mapped form (production / WAN). The raw
# http://host:8001 form is only safe over a localhost / SSH-tunneled
# loopback — `_validate_qwen_url` warns but does NOT reject it, and your
# chat prompts (which include RAG context + system instructions) will
# travel in plaintext if you point production at the bare http URL.
#
# Migration note: if your existing .env still points at the legacy
# Gradio service (URL ends in `.gradio.live`), update to the new
# serve_openai.py port — backend startup now logs a warning when it
# detects the legacy hostname.
# QWEN_RAFT_URL=https://your-autodl-mapped-host       # service root; /v1 suffix tolerated
# QWEN_RAFT_TOKEN=                                    # optional bearer (if you front it with a proxy)
# QWEN_RAFT_MODEL_NAME=qwen2.5-7b-raft                # surfaced as LLMResponse.model
# QWEN_RAFT_HTTP_TIMEOUT=60                           # read-phase timeout; connect/write/pool
                                                      # are clamped tighter internally (10/10/5s)
# QWEN_BACKEND_TIMEOUT_SECONDS=30                     # chat-path budget (outer wait_for)
# QWEN_HEALTH_TTL_SECONDS=15                          # /api/status health probe cache

# ── Exam Prep (R5-2 closed-loop skill) ────────────────────────────────
# EXAM_PREP_LLM_TIMEOUT_SECONDS=45      # per-LLM-call timeout for plan + variant gen
# EXAM_PREP_VARIANT_CONCURRENCY=4       # max concurrent codex calls during submit variant gen

# ── KG extraction (Stage A topics + Stage B per-chunk) ────────────────
# KG_STAGE_B_CONCURRENCY=10            # max parallel per-chunk Stage B LLM calls (10 is the
                                       # safe default for codex; bump on higher-throughput
                                       # backends, lower if you see rate-limit errors)
# KG_STAGE_A_TIMEOUT_SECONDS=30        # per-file Stage A wall-clock budget — codex cold-start
                                       # plus a 30-chunk-head prompt often brushes past 15s on
                                       # the first call; 30s gives headroom without hiding hangs
